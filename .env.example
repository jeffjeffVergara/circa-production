# ══════════════════════════════════════════════
# CIRCA MVP — Environment Variables
# ══════════════════════════════════════════════

# ── Supabase ──
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOi...

# ── Twilio ──
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── App ──
APP_BASE_URL=https://your-app.railway.app
# Zona horaria para fecha/hora en contratos y firmas (IANA), Perú = GMT-5
APP_TZ=America/Lima
YAPE_PHONE=987654321
PLIN_PHONE=987654321
# WhatsApp de soporte Circa (solo dígitos, con código de país). Menú → "Contactar a Circa".
CIRCA_SOPORTE_WHATSAPP=51999888777

# ── SUNAT / RENIEC API ──
# Provider: apiinti | peruapi | apiperu
PERU_API_PROVIDER=apiinti
PERU_API_TOKEN=your_api_token_here

# ── Biometrics ──
# strict (recomendado) | legacy (rollback rapido)
BIOMETRIA_MODE=strict
# Selfie vs foto DNI (0.0–1.0). Bajar min_score reduce falsos negativos; subir override exige mas coincidencia para ignorar face_match=false.
FACE_MATCH_MIN_SCORE=0.56
FACE_MATCH_SCORE_OVERRIDE=0.64

# ── WhatsApp Flow IDs ──
# Legacy (único flow para crear/verificar PIN)
FLOW_PIN_ID=
# Recomendado: flujos separados
FLOW_PIN_CREATE_ID=
FLOW_PIN_VERIFY_ID=

# ── Backoffice soporte ──
BACKOFFICE_EMAIL=soporte@circa.pe
BACKOFFICE_PASSWORD=cambia-esta-clave-en-prod
# Usuario solo lectura (consulta sin crear/editar/borrar)
# Opción A — una sola variable (recomendado en Railway):
BACKOFFICE_VIEWER_CREDENTIALS=lectura@circa.pe:cambia-esta-clave-lectura
# Opción B — email y password por separado:
BACKOFFICE_VIEWER_EMAIL=lectura@circa.pe
BACKOFFICE_VIEWER_PASSWORD=cambia-esta-clave-lectura
BACKOFFICE_JWT_SECRET=genera-un-secreto-largo-aleatorio
BACKOFFICE_TOKEN_TTL_SEC=28800
# Token legacy API (/api/distribuidor/admin/*); UI admin migró a /backoffice
CIRCA_ADMIN_TOKEN=circa-admin-2026

# ── Distribuidor ──
DISTRIBUIDOR_WA_NUMERO=+51987654321

# ── Content Template SIDs (from Twilio Content Editor) ──
TWILIO_TEMPLATE_MENU=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TEMPLATE_CATEGORIAS=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TEMPLATE_PRODUCTOS_BEBIDAS=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TEMPLATE_PRODUCTOS_LACTEOS=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TEMPLATE_PRODUCTOS_ABARROTES=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TEMPLATE_PRODUCTOS_CUIDADO=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TEMPLATE_PACK=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TEMPLATE_CANTIDAD=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TEMPLATE_ITEM_AGREGADO=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TEMPLATE_CARRITO=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TEMPLATE_MONTO=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TEMPLATE_PLAZO=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TEMPLATE_LINEA=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
