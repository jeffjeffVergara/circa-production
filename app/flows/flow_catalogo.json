{
  "version": "7.0",
  "data_api_version": "3.0",
  "routing_model": {
    "CATALOG": ["SUCCESS"],
    "SUCCESS": []
  },
  "screens": [
    {
      "id": "CATALOG",
      "title": "Catalogo Circa",
      "data": {
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "main-content": {
                "type": "object",
                "properties": {
                  "title": { "type": "string" },
                  "description": { "type": "string" }
                }
              }
            }
          },
          "__example__": [
            { "id": "1", "main-content": { "title": "T", "description": "D" } }
          ]
        },
        "bodega_id": {
          "type": "string",
          "__example__": "b1"
        },
        "cart_state": {
          "type": "string",
          "__example__": "{}"
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "NavigationList",
            "name": "selection",
            "label": "Que buscas hoy?",
            "list-items": "${data.items}",
            "on-click-action": {
              "name": "data_exchange",
              "payload": {
                "selected": "${form.selection}",
                "bodega_id": "${data.bodega_id}",
                "cart_state": "${data.cart_state}"
              }
            }
          }
        ]
      }
    },
    {
      "id": "SUCCESS",
      "title": "Listo",
      "terminal": true,
      "data": {
        "message": {
          "type": "string",
          "__example__": "OK"
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          { "type": "TextHeading", "text": "${data.message}" },
          { "type": "TextBody", "text": "Gracias por tu pedido." }
        ]
      }
    }
  ]
}
