{
  "version": "7.0",
  "data_api_version": "3.0",
  "routing_model": {
    "CATEGORIAS": ["PRODUCTOS"],
    "PRODUCTOS": ["DETALLE"],
    "DETALLE": ["AGREGADO"],
    "AGREGADO": ["CATEGORIAS", "CARRITO"],
    "CARRITO": ["CATEGORIAS", "MONTO"],
    "MONTO": ["PLAZO"],
    "PLAZO": ["RESUMEN_PIN"],
    "RESUMEN_PIN": ["SUCCESS"],
    "SUCCESS": []
  },
  "screens": [
    {
      "id": "CATEGORIAS",
      "title": "Catálogo Circa",
      "data": {
        "categorias": {
          "type": "array",
          "__example__": [
            {"id": "bebidas", "title": "Bebidas", "description": "Gaseosas, agua, jugos"},
            {"id": "lacteos", "title": "Lácteos", "description": "Leche, yogurt, quesos"},
            {"id": "abarrotes", "title": "Abarrotes", "description": "Limpieza, azúcar, aceite"},
            {"id": "cuidado", "title": "Cuidado", "description": "Shampoo, pañales, higiene"}
          ]
        },
        "bodega_id": {
          "type": "string",
          "__example__": "b0000000-0000-0000-0000-000000000000"
        },
        "distribuidor_id": {
          "type": "string",
          "__example__": "d0000000-0000-0000-0000-000000000000"
        },
        "cart_summary": {
          "type": "string",
          "__example__": ""
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "NavigationList",
            "name": "cat_selection",
            "label": "¿Qué buscas hoy?",
            "list-items": "${data.categorias}",
            "on-click-action": {
              "name": "data_exchange",
              "payload": {
                "categoria": "${form.cat_selection}",
                "bodega_id": "${data.bodega_id}",
                "distribuidor_id": "${data.distribuidor_id}"
              }
            }
          }
        ]
      }
    },

    {
      "id": "PRODUCTOS",
      "title": "Productos",
      "refresh_on_back": true,
      "data": {
        "productos": {
          "type": "array",
          "__example__": [
            {
              "id": "prod1",
              "title": "Coca-Cola 500ml",
              "description": "DistribuMax",
              "end": {"title": "S/9.60", "description": "Pack 6"}
            }
          ]
        },
        "categoria": {
          "type": "string",
          "__example__": "Bebidas"
        },
        "bodega_id": {
          "type": "string",
          "__example__": "b0000000-0000-0000-0000-000000000000"
        },
        "distribuidor_id": {
          "type": "string",
          "__example__": "d0000000-0000-0000-0000-000000000000"
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "NavigationList",
            "name": "prod_selection",
            "label": "${data.categoria}",
            "list-items": "${data.productos}",
            "on-click-action": {
              "name": "data_exchange",
              "payload": {
                "producto_id": "${form.prod_selection}",
                "bodega_id": "${data.bodega_id}"
              }
            }
          }
        ]
      }
    },

    {
      "id": "DETALLE",
      "title": "Detalle",
      "data": {
        "producto_id": {
          "type": "string",
          "__example__": "prod1"
        },
        "nombre": {
          "type": "string",
          "__example__": "Coca-Cola 500ml"
        },
        "distribuidor": {
          "type": "string",
          "__example__": "DistribuMax"
        },
        "categoria": {
          "type": "string",
          "__example__": "Bebidas"
        },
        "packs": {
          "type": "array",
          "__example__": [
            {"id": "6", "title": "Pack 6 — S/9.60"},
            {"id": "12", "title": "Pack 12 — S/18.00"},
            {"id": "24", "title": "Pack 24 — S/34.00"}
          ]
        },
        "cantidades": {
          "type": "array",
          "__example__": [
            {"id": "1", "title": "1"},
            {"id": "2", "title": "2"},
            {"id": "3", "title": "3"}
          ]
        },
        "bodega_id": {
          "type": "string",
          "__example__": "b0000000-0000-0000-0000-000000000000"
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "Form",
            "name": "detalle_form",
            "children": [
              {
                "type": "TextSubheading",
                "text": "${data.nombre}"
              },
              {
                "type": "TextCaption",
                "text": "${data.distribuidor} · ${data.categoria}"
              },
              {
                "type": "RadioButtonsGroup",
                "name": "pack",
                "label": "Tamaño de pack",
                "required": true,
                "data-source": "${data.packs}"
              },
              {
                "type": "Dropdown",
                "name": "cantidad",
                "label": "Cantidad de packs",
                "required": true,
                "data-source": "${data.cantidades}"
              },
              {
                "type": "Footer",
                "label": "Agregar al carrito 🛒",
                "on-click-action": {
                  "name": "data_exchange",
                  "payload": {
                    "producto_id": "${data.producto_id}",
                    "pack": "${form.pack}",
                    "cantidad": "${form.cantidad}",
                    "bodega_id": "${data.bodega_id}"
                  }
                }
              }
            ]
          }
        ]
      }
    },

    {
      "id": "AGREGADO",
      "title": "Agregado",
      "data": {
        "mensaje": {
          "type": "string",
          "__example__": "✅ 2x Pack 12 Coca-Cola 500ml — S/36.00"
        },
        "carrito_resumen": {
          "type": "string",
          "__example__": "Carrito: 5 packs · S/187.80"
        },
        "bodega_id": {
          "type": "string",
          "__example__": "b0000000-0000-0000-0000-000000000000"
        },
        "acciones": {
          "type": "array",
          "__example__": [
            {"id": "mas", "title": "+ Agregar más productos"},
            {"id": "revisar", "title": "🛒 Revisar carrito"}
          ]
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "Form",
            "name": "agregado_form",
            "children": [
              {
                "type": "TextSubheading",
                "text": "${data.mensaje}"
              },
              {
                "type": "TextBody",
                "text": "${data.carrito_resumen}"
              },
              {
                "type": "RadioButtonsGroup",
                "name": "accion",
                "label": "¿Qué deseas hacer?",
                "required": true,
                "data-source": "${data.acciones}"
              },
              {
                "type": "Footer",
                "label": "Continuar →",
                "on-click-action": {
                  "name": "data_exchange",
                  "payload": {
                    "accion": "${form.accion}",
                    "bodega_id": "${data.bodega_id}"
                  }
                }
              }
            ]
          }
        ]
      }
    },

    {
      "id": "CARRITO",
      "title": "Tu carrito",
      "refresh_on_back": true,
      "data": {
        "items_text": {
          "type": "string",
          "__example__": "2x Pk12 Coca-Cola 500ml — S/36.00\n1x Pk6 Ariel 400g — S/31.80"
        },
        "total_label": {
          "type": "string",
          "__example__": "S/187.80"
        },
        "linea_info": {
          "type": "string",
          "__example__": "Línea: S/500.00. Financias hasta S/187.80"
        },
        "bodega_id": {
          "type": "string",
          "__example__": "b0000000-0000-0000-0000-000000000000"
        },
        "total": {
          "type": "number",
          "__example__": 187.80
        },
        "acciones_carrito": {
          "type": "array",
          "__example__": [
            {"id": "financiar", "title": "💚 Financiar con Circa"},
            {"id": "agregar", "title": "+ Agregar más productos"},
            {"id": "vaciar", "title": "🗑 Vaciar carrito"}
          ]
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "Form",
            "name": "carrito_form",
            "children": [
              {
                "type": "TextSubheading",
                "text": "🛒 Tu carrito"
              },
              {
                "type": "TextBody",
                "text": "${data.items_text}"
              },
              {
                "type": "TextSubheading",
                "text": "Total: ${data.total_label}"
              },
              {
                "type": "TextCaption",
                "text": "${data.linea_info}"
              },
              {
                "type": "RadioButtonsGroup",
                "name": "accion",
                "label": "¿Qué deseas hacer?",
                "required": true,
                "data-source": "${data.acciones_carrito}"
              },
              {
                "type": "Footer",
                "label": "Continuar →",
                "on-click-action": {
                  "name": "data_exchange",
                  "payload": {
                    "accion": "${form.accion}",
                    "bodega_id": "${data.bodega_id}",
                    "total": "${data.total}"
                  }
                }
              }
            ]
          }
        ]
      }
    },

    {
      "id": "MONTO",
      "title": "Financiamiento",
      "data": {
        "total": {
          "type": "number",
          "__example__": 970.40
        },
        "opciones": {
          "type": "array",
          "__example__": [
            {"id": "500.00", "title": "100% — S/500.00"},
            {"id": "250.00", "title": "50% — S/250.00"},
            {"id": "125.00", "title": "25% — S/125.00"}
          ]
        },
        "bodega_id": {
          "type": "string",
          "__example__": "b0000000-0000-0000-0000-000000000000"
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "Form",
            "name": "monto_form",
            "children": [
              {
                "type": "TextSubheading",
                "text": "💰 ¿Cuánto deseas financiar?"
              },
              {
                "type": "TextCaption",
                "text": "El resto se paga al contado en la entrega."
              },
              {
                "type": "RadioButtonsGroup",
                "name": "monto",
                "label": "Monto a financiar",
                "required": true,
                "data-source": "${data.opciones}"
              },
              {
                "type": "Footer",
                "label": "Continuar →",
                "on-click-action": {
                  "name": "data_exchange",
                  "payload": {
                    "monto": "${form.monto}",
                    "bodega_id": "${data.bodega_id}",
                    "total": "${data.total}"
                  }
                }
              }
            ]
          }
        ]
      }
    },

    {
      "id": "PLAZO",
      "title": "Plazo de pago",
      "data": {
        "monto_financiar": {
          "type": "number",
          "__example__": 250.00
        },
        "contado": {
          "type": "number",
          "__example__": 720.40
        },
        "total": {
          "type": "number",
          "__example__": 970.40
        },
        "plazos": {
          "type": "array",
          "__example__": [
            {"id": "7", "title": "7 días — Fee S/12.50 — Total S/262.50"},
            {"id": "15", "title": "15 días — Fee S/20.00 — Total S/270.00"},
            {"id": "30", "title": "30 días — Fee S/30.00 — Total S/280.00"}
          ]
        },
        "bodega_id": {
          "type": "string",
          "__example__": "b0000000-0000-0000-0000-000000000000"
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "Form",
            "name": "plazo_form",
            "children": [
              {
                "type": "TextSubheading",
                "text": "📅 Elige plazo de pago"
              },
              {
                "type": "TextBody",
                "text": "Financiar: S/${data.monto_financiar}"
              },
              {
                "type": "RadioButtonsGroup",
                "name": "plazo",
                "label": "Plazo",
                "required": true,
                "data-source": "${data.plazos}"
              },
              {
                "type": "Footer",
                "label": "Confirmar →",
                "on-click-action": {
                  "name": "data_exchange",
                  "payload": {
                    "plazo": "${form.plazo}",
                    "monto_financiar": "${data.monto_financiar}",
                    "total": "${data.total}",
                    "bodega_id": "${data.bodega_id}"
                  }
                }
              }
            ]
          }
        ]
      }
    },

    {
      "id": "RESUMEN_PIN",
      "title": "Confirmar pedido",
      "data": {
        "resumen_text": {
          "type": "string",
          "__example__": "Pedido: S/970.40\nFinanciar: S/250.00\nTasa: 5.0%\nPlazo: 7 días\nFee: S/12.50\nTotal crédito: S/262.50\nContado: S/720.40"
        },
        "bodega_id": {
          "type": "string",
          "__example__": "b0000000-0000-0000-0000-000000000000"
        },
        "pedido_total": {
          "type": "number",
          "__example__": 970.40
        },
        "monto_financiado": {
          "type": "number",
          "__example__": 250.00
        },
        "tasa": {
          "type": "number",
          "__example__": 0.05
        },
        "plazo_dias": {
          "type": "number",
          "__example__": 7
        },
        "fee": {
          "type": "number",
          "__example__": 12.50
        },
        "total_credito": {
          "type": "number",
          "__example__": 262.50
        },
        "pago_contado": {
          "type": "number",
          "__example__": 720.40
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "Form",
            "name": "pin_form",
            "children": [
              {
                "type": "TextSubheading",
                "text": "🔐 Confirma tu pedido"
              },
              {
                "type": "TextBody",
                "text": "${data.resumen_text}"
              },
              {
                "type": "TextCaption",
                "text": "⏱ Tienes 5 minutos para confirmar."
              },
              {
                "type": "TextInput",
                "name": "pin",
                "label": "Clave Circa",
                "input-type": "passcode",
                "required": true,
                "min-chars": 4,
                "max-chars": 4,
                "helper-text": "Ingresa tu clave de 4 dígitos"
              },
              {
                "type": "Footer",
                "label": "Confirmar pedido 🔐",
                "on-click-action": {
                  "name": "data_exchange",
                  "payload": {
                    "pin": "${form.pin}",
                    "bodega_id": "${data.bodega_id}",
                    "pedido_total": "${data.pedido_total}",
                    "monto_financiado": "${data.monto_financiado}",
                    "tasa": "${data.tasa}",
                    "plazo_dias": "${data.plazo_dias}",
                    "fee": "${data.fee}",
                    "total_credito": "${data.total_credito}",
                    "pago_contado": "${data.pago_contado}"
                  }
                }
              }
            ]
          }
        ]
      }
    },

    {
      "id": "SUCCESS",
      "title": "¡Pedido confirmado!",
      "terminal": true,
      "data": {
        "order_number": {
          "type": "string",
          "__example__": "#CRC-001"
        },
        "message": {
          "type": "string",
          "__example__": "Tu pedido ha sido confirmado. Recibirás actualizaciones por WhatsApp."
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextSubheading",
            "text": "✅ ¡Pedido confirmado!"
          },
          {
            "type": "TextSubheading",
            "text": "${data.order_number}"
          },
          {
            "type": "TextBody",
            "text": "${data.message}"
          }
        ]
      }
    }
  ]
}
